# Trade Bot v4 — limit buy both @ 0.45 at open, sell if < 0.15, auto-redeem. Copy to .env and fill in.

# Required: Polymarket trading
PRIVATE_KEY=
PROXY_WALLET_ADDRESS=
CHAIN_ID=137

# CLOB (optional)
# CLOB_API_URL=https://clob.polymarket.com
# REALTIME_PRICE_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Credential path (relative to cwd or repo root)
# CREDENTIAL_PATH=src/data/credential.json

# Market: BTC 5m default
MARKET_SLUG_PREFIX=btc-updown-5m-
MARKET_WINDOW_MINUTES=5

# Strategy: limit buy both sides at open (only in first BUY_WINDOW_SEC after market start)
BUY_LIMIT_PRICE=0.45
BUY_AMOUNT_USD=5
# Only place orders when elapsed since market start < this (seconds). Default 60 = first 1 minute.
BUY_WINDOW_SEC=60

# Sell position when mid price drops below this (stop-loss)
SELL_IF_BELOW=0.15
# When stop-loss selling, sell at (price - SELL_LAG), e.g. 0.12 → 0.11
SELL_LAG=0.01

# After market end, redeem winning tokens when condition is resolved
AUTO_REDEEM=true

# Trading
ENABLE_TRADING=true

# Loop interval (ms)
# BOT_LOOP_MS=500

# RPC (optional; for allowance and redeem)
# RPC_URL=
# RPC_TOKEN=
