# Trade Bot v3 — 0.35 strategy. Copy to .env and fill in.

# Required: Polymarket trading
PRIVATE_KEY=
PROXY_WALLET_ADDRESS=
CHAIN_ID=137

# CLOB (optional)
# CLOB_API_URL=https://clob.polymarket.com
# REALTIME_PRICE_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Credential path (relative to cwd or repo root)
# CREDENTIAL_PATH=src/data/credential.json

# Market: BTC 5m default
MARKET_SLUG_PREFIX=btc-updown-5m-
MARKET_WINDOW_MINUTES=5

# Strategy: GTD limit buy at 0.35, lifetime 2 min 30 s
BUY_TARGET_PRICE=0.35
GTD_LIFETIME_SEC=150
GTD_BUFFER_SEC=60
# Target side: Up | Down | auto (auto = side with lower ask)
TARGET_OUTCOME=auto
BUY_AMOUNT_USD=5

# Sell: 50% when mid >= 0.4, 50% when mid >= 0.5
SELL_T1_PRICE=0.4
SELL_T1_RATIO=0.5
SELL_T2_PRICE=0.5
SELL_T2_RATIO=0.5

# Trading
ENABLE_TRADING=true

# Loop interval (ms)
# BOT_LOOP_MS=500

# RPC (optional; for allowance)
# RPC_URL=
# RPC_TOKEN=
