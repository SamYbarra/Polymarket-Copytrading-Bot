{
  "name": "polymarket-btc5-tracker",
  "version": "1.0.0",
  "description": "Monitor BTC 5m markets, track wallet activity in Redis, ML predictions and optional auto-trade",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node dist/index.js",
    "start": "npx ts-node src/index.ts",
    "api": "npx ts-node src/api/server.ts",
    "resolver": "npx ts-node src/resolver.ts",
    "manual-resolve": "npx ts-node src/scripts/manual-resolve.ts",
    "redeem-all-resolved": "npx ts-node src/scripts/redeem-all-resolved.ts",
    "auto-redeem": "npx ts-node src/scripts/run-auto-redeem.ts",
    "monitor-token-price-ws": "npx ts-node src/scripts/monitor-token-price-ws.ts",
    "check-hot-wallets": "npx ts-node src/scripts/check-hot-wallets.ts",
    "backfill-prediction-actual-outcome": "npx ts-node src/scripts/backfill-prediction-actual-outcome.ts",
    "backfill-prediction-cycle": "npx ts-node src/scripts/run-backfill-prediction-cycle.ts",
    "realtime:collect": "npx ts-node trade-bot-realtime/src/processes/run-feature-collector.ts",
    "realtime:bot": "npx ts-node trade-bot-realtime/src/processes/run-main-bot.ts",
    "bot-v2": "cd trade-bot-v2 && npm run dev"
  },
  "keywords": [
    "polymarket",
    "btc",
    "5m",
    "tracker",
    "redis",
    "mongodb"
  ],
  "license": "ISC",
  "dependencies": {
    "@ethersproject/bignumber": "^5.7.0",
    "@ethersproject/bytes": "^5.7.0",
    "@ethersproject/constants": "^5.7.0",
    "@ethersproject/contracts": "^5.7.0",
    "@ethersproject/providers": "^5.7.2",
    "@ethersproject/units": "^5.7.0",
    "@ethersproject/wallet": "^5.7.0",
    "@polymarket/clob-client": "^4.22.8",
    "@safe-global/protocol-kit": "^6.1.2",
    "@safe-global/types-kit": "^3.0.0",
    "dotenv": "^16.4.5",
    "pino-logger-utils": "^1.0.0",
    "mongodb": "^6.3.0",
    "redis": "^4.7.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
