# Min wallet total (USD) per market for features/results; all fills are stored
MIN_BUY_USD=10

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB connection (use separate DB for 5m)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=polymarket_btc5

# Market config (5m window; override if needed)
MARKET_WINDOW_MINUTES=5
# MARKET_SLUG_PREFIX=btc-updown-5m-

# Poll interval for checking markets (seconds)
POLL_INTERVAL_SECONDS=30

# Hot wallet detection (for ML predictions; 60 × 5m ≈ 5h window)
MIN_HOT_WALLET_WIN_RATE=70
MIN_HOT_WALLET_RECENT_TRADES=10
HOT_WALLET_RECENT_MARKETS=60

# Prediction settings (5m window: predict when elapsed is in [min, max] and readiness gate passes)
PREDICTION_TIME_MINUTES=3
PREDICTION_TIME_MIN=2
PREDICTION_TIME_MAX=4
# Min seconds after market start before predict/buy (default 150 = 2m 30s). No prediction or buy before this.
# PREDICTION_MIN_ELAPSED_SECONDS=150
# Readiness gate: only predict when total volume (USD) and wallet count meet minimums (0 = disabled)
# MIN_VOLUME_FOR_PREDICTION=100
# MIN_TRADES_FOR_PREDICTION=3
# Retry prediction every N seconds until we fill a buy (next process cycle after N s). Default 20.
# PREDICTION_RETRY_INTERVAL_SECONDS=20
# Full positions sync (heavy) every N seconds; between syncs we use lightweight trades. Default 90.
# POSITIONS_SYNC_INTERVAL_SECONDS=90
LARGE_TRADE_THRESHOLD_USD=100

# Optional: XGBoost real-time prediction service
# ML_SERVICE_URL=http://localhost:8005

# Auto-train ML model after each resolved market (resolver process). Set to false to disable.
# ENABLE_ML_AUTO_TRAIN=true
# PYTHON_CMD=python3

# ML buy (requires trading credentials). Redeem runs in a separate process — see below.
# ENABLE_ML_BUY=true
# Profit Lock: partial exits + trailing (default true). Set ENABLE_PROFIT_LOCK=false to hold to resolution only.
# ENABLE_PROFIT_LOCK=true
# ENABLE_AUTO_REDEEM=true  # only used when running npm run auto-redeem
# ML_BUY_AMOUNT_USD=5
# ML_BUY_MIN_CONFIDENCE=0.7   — only attempt buy when prediction confidence >= this
# ML_BUY_MIN_CONFIDENCE_AT_EARLY_TIME=0.8 — when predicting at PREDICTION_TIME_MIN (earliest time), require confidence > 80% to buy
# ENSEMBLE_BUY_ALLOWED=false  — if false, never buy when using ensemble (ML down)
# ENSEMBLE_MIN_CONFIDENCE=0.85 — when ensemble allowed, require this confidence to buy
# APPROVE_CALL_PERIOD_SECONDS=300 — min seconds between USDC approve calls in tracker (0 = every cycle; default 300)
# PRIVATE_KEY=your_ethereum_private_key
# PROXY_WALLET_ADDRESS=your_polymarket_proxy_safe_address
# CHAIN_ID=137
# RPC_TOKEN=your_alchemy_token
# Copy src/data/credential.json from polymarket-copytrading-bot-ts (or run createCredential there)

# Redeem (run in separate process; not in main bot):
#   npm run auto-redeem         — ML positions from token-holding.json, 160s, optional MongoDB history
#   npm run redeem-all-resolved — all redeemable positions via Data API, 500s
# Both need PRIVATE_KEY, PROXY_WALLET_ADDRESS (and CLOB_API_URL if using proxy).

# Prediction buy filter (only buy when all pass). Price checks use execution price (best ask).
# SAFE_DELTA=100       — min |currentBtc - btcOpen| (USD); skip when market flat
# BUY_PRICE_MIN=0.35   — skip if best ask <= this
# BUY_PRICE_MAX=0.65   — keep below 0.7 so confidence > price is achievable (+EV)
# BUY_MAX_SPREAD=0.1   — skip if (bestAsk - bestBid) > this (0 = disabled)
# BUY_SHARES=5
# Note: Bot also requires confidence > execution price (best ask) for positive expected value.

# BTC price: primary Binance; optional fallback when Binance fails (default CoinGecko)
# BTC_FALLBACK_URL=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd

# RealtimePriceService (optional)
# REALTIME_PRICE_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# REALTIME_PRICE_PING_INTERVAL_MS=10000
# REALTIME_PRICE_PONG_TIMEOUT_MS=15000
