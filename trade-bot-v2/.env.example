# Trade Bot v2 — copy to .env and fill in. All paths relative to trade-bot-v2 when running from this folder.

# Required: Polymarket trading
PRIVATE_KEY=
PROXY_WALLET_ADDRESS=
CHAIN_ID=137

# CLOB (optional overrides)
# CLOB_API_URL=https://clob.polymarket.com
# REALTIME_PRICE_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Credential path: relative to repo root or cwd (e.g. src/data/credential.json)
# CREDENTIAL_PATH=src/data/credential.json

# Market: slug prefix + window. BTC 5m default; use eth-updown-5m- for ETH 5m up/down.
MARKET_SLUG_PREFIX=btc-updown-5m-
# MARKET_SLUG_PREFIX=eth-updown-5m-
MARKET_WINDOW_MINUTES=5
# Velocity uses the same asset as the market. Override if needed (default: derived from slug prefix).
# VELOCITY_ASSET=btc
# VELOCITY_ASSET=eth

# Buy: only when best ask in (MIN, MAX) and confidence >= MIN_CONFIDENCE
BUY_PRICE_MIN=0.4
BUY_PRICE_MAX=0.8
MIN_CONFIDENCE=0.65
# Buy size in USD. Shares = BUY_AMOUNT_USD / token price. (BUY_SHARES still used as default if BUY_AMOUNT_USD unset)
BUY_AMOUNT_USD=5
# Wider band / chase when velocity strongly favorable: max price (default 0.92), min velocity $/s (default 8), size ratio (default 0.5)
# BUY_PRICE_MAX_FAVORABLE=0.92
# VELOCITY_FAVORABLE_FOR_WIDER_BAND=8
# BUY_AMOUNT_FAVORABLE_RATIO=0.5
# After buy: limit sell order at this price for all tokens (default 0.97)
# LIMIT_SELL_PRICE=0.97
# When flattening or profit-lock selling: market (immediate) or limit (post at price). Default: market
# SELL_ORDER_TYPE=market
# SELL_ORDER_TYPE=limit

# No buy before this many seconds after market start
PREDICTION_MIN_ELAPSED_SECONDS=150
# Never buy after this many seconds (default 270 = 4 min 30 s)
# BUY_MAX_ELAPSED_SECONDS=270

# Trading
# ENABLE_ML_BUY=true
# ML prediction: Redis (features from realtime collector) + optional ML service. See docs/ml-prediction.md
# REDIS_URL=redis://localhost:6379
# ML_SERVICE_URL=http://localhost:8000

# Loop speed (ms)
# BOT_LOOP_MS=100

# Profit lock
# PROFIT_LOCK_SELL_ALL_ABOVE=0.97  # if mid > this, sell all (any case)
# FLATTEN_BY_MIN=4.5
# PL_ALPHA1=0.20
# PL_ALPHA2=0.50
# PL_R1=0.30
# PL_R2=0.50
# PL_TRAIL_MIN=0.025
# PL_TRAIL_MAX=0.10
# PL_COLLAPSE=0.10
# RESOLUTION_SOON_SEC=60
# PL_T2_BOOST_MAX_ALPHA=0.15
# PL_T2_BOOST_VELOCITY_SCALE=0.01

# Velocity risk (Chainlink Data Streams WebSocket — required for velocity layer)
# VELOCITY_ENABLED=true
CHAINLINK_DS_WS_URL=wss://ws.dataengine.chain.link
CHAINLINK_DS_API_URL=https://api.dataengine.chain.link
CHAINLINK_DS_FEED_ID_BTC_USD=
CHAINLINK_DS_API_KEY=
CHAINLINK_DS_USER_SECRET=

# VELOCITY_WINDOW_SEC=30
# VELOCITY_SKIP_BUY_ON_ANY_ADVERSE=true
# When true: skip buy whenever velocity is adverse to outcome (Up + BTC down, or Down + BTC up). When false: block only when adverse and above VELOCITY_BLOCK_USD_PER_SEC.
# VELOCITY_BLOCK_USD_PER_SEC=15
# VELOCITY_REDUCE_USD_PER_SEC=8
# VELOCITY_TIGHTEN_USD_PER_SEC=5
# For ETH, velocity $/s is smaller than BTC at same % move; you may want lower thresholds.
# INSUFFICIENT_MOMENTUM_MIN_PROJECTED_USD=50
# FLATTEN_TIGHTEN_MULT=0.7
# TRAIL_TIGHTEN_MULT=1.5
