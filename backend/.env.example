# Minimum buy amount (USD) to track a wallet
MIN_BUY_USD=10

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB connection (use separate DB for 5m)
MONGODB_URI=mongodb+srv://onlybitcoin:kig020829@cluster0.9koasrn.mongodb.net/?appName=Cluster0
MONGODB_DB=polymarket_btc5

# Market config (5m window; override if needed)
MARKET_WINDOW_MINUTES=5

# Poll interval for checking markets (seconds)
POLL_INTERVAL_SECONDS=30

# Hot wallet detection (for ML predictions; 60 × 5m ≈ 5h window)
MIN_HOT_WALLET_WIN_RATE=70
MIN_HOT_WALLET_RECENT_TRADES=20
HOT_WALLET_RECENT_MARKETS=60

# Prediction settings (5m window: predict when elapsed is in [min, max])
PREDICTION_TIME_MINUTES=3
PREDICTION_TIME_MIN=2
PREDICTION_TIME_MAX=4
LARGE_TRADE_THRESHOLD_USD=100

# Optional: XGBoost real-time prediction service (uncomment when running predict_server)
ML_SERVICE_URL=http://localhost:8005

# Auto-train ML model after each resolved market
ENABLE_ML_AUTO_TRAIN=false
PYTHON_CMD=python3

# ML buy & auto-redeem — uncomment and set below to enable trading
