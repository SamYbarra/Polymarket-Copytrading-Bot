# BTC price: Binance primary, optional fallback
BTC_PRICE_URL=https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT
# BTC_FALLBACK_URL=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd

# PostgreSQL for vol_regime_history
DATABASE_URL=postgresql://user:password@localhost:5432/regime_db

# Regime engine: short window = ~3 bars, long = ~20 bars (1-min)
REGIME_SHORT_WINDOW=3
REGIME_LONG_WINDOW=20
REGIME_UPDATE_INTERVAL_SEC=10

# API / WebSocket
API_HOST=0.0.0.0
API_PORT=8006
